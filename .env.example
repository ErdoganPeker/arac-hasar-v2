# .env.example — repo-root combined template
# ----------------------------------------------------------------------
# This file is read by docker-compose.yml via env_file references inside
# the service-level .env files, and used as a starting point for new
# devs. Copy to .env and fill in real values for local-only secrets.
#
# Per-service envs live at:
#   services/backend/.env        (copy from services/backend/.env.example)
#   apps/web/.env.local          (copy from apps/web/.env.example)
#   apps/desktop/.env            (copy from apps/desktop/.env.example)
#   apps/mobile/.env             (copy from apps/mobile/.env.example)
# ----------------------------------------------------------------------

# === Environment ===
ENVIRONMENT=development
API_VERSION=0.2.0

# === Backend (FastAPI) ===
# Tenant API keys, comma-separated. Empty => dev mode (no auth).
API_KEYS=dev_key_change_me
JWT_SECRET_KEY=change_me_in_production_min_32_chars_long_xxxxxxxxxx
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_now

# === Database ===
# Local dev points at docker compose 'postgres' service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arac_hasar

# === Redis (Celery broker + WS pub/sub) ===
REDIS_URL=redis://localhost:6379/0

# === S3 / MinIO (local dev defaults) ===
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=inspections

# === Model weights (S3 bucket for production fetch) ===
# Leave empty in dev — local weights are mounted into the container.
MODEL_S3_BUCKET=
MODEL_S3_PREFIX=models/full_20260515_044630

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:1420,http://localhost:8081,tauri://localhost
CORS_ORIGIN_REGEX=

# === Frontend (Next.js public) ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Observability (optional) ===
SENTRY_DSN=
