# Mobile (Expo) environment template
# Copy to .env.local or .env and configure for your environment.

# Backend API base URL (no trailing slash)
# Android emulator: http://10.0.2.2:8000
# iOS simulator:    http://localhost:8000
# Physical device:  http://<your-LAN-ip>:8000
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Optional API key (if backend requires X-API-Key)
EXPO_PUBLIC_API_KEY=

# Default app language (tr | en). Empty = device language detection.
EXPO_PUBLIC_DEFAULT_LOCALE=tr
