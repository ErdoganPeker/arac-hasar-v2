{
  "expo": {
    "name": "Hasarİ",
    "slug": "arac-hasar-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "hasari",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aracHasar.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Araç hasarını tespit etmek için kameraya erişim gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Hasar fotoğraflarını yüklemek için galeriye erişim gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "İnceleme sonuçlarını kaydetmek için galeriye yazma izni gerekiyor."
      }
    },
    "android": {
      "package": "com.aracHasar.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Hasarİ kameraya erişmek istiyor — araç fotoğrafları için."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Hasarİ galeriye erişmek istiyor — yüklenecek fotoğrafları seçmek için."
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
